# Groq API key — get a free one at https://console.groq.com/keys
# NO "VITE_" prefix: Vite inlines any VITE_-prefixed var into the public client
# JS bundle, which would expose the key in the browser. This one is read
# server-side only by api/chat.js (Vercel serverless function) via
# process.env.GROQ_API_KEY, so it must stay non-VITE_-prefixed.
GROQ_API_KEY=your_groq_key_here

# EmailJS — get these from https://dashboard.emailjs.com
# These are intentionally VITE_-prefixed: EmailJS's SDK is designed so the
# public key / service / template IDs are safe to expose in the browser
# (they only allow sending templated emails, not account access).
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
